<?xml version="1.0" standalone='no'?>
<!DOCTYPE service-group SYSTEM "avahi-service.dtd">

<!--
  Avahi / mDNS service registration for power-bridge.
  Install to: /etc/avahi/services/power-bridge.service
  After install: systemctl restart avahi-daemon
-->

<service-group>
  <name replace-wildcards="yes">power-bridge on %h</name>

  <!-- HTTP service so browsers can find the status page -->
  <service>
    <type>_http._tcp</type>
    <port>80</port>
    <txt-record>path=/</txt-record>
  </service>

  <!-- Shelly discovery record (used by Marstek, Noah, Hoymiles auto-discovery) -->
  <service>
    <type>_shelly._tcp</type>
    <port>80</port>
    <txt-record>gen=2</txt-record>
    <txt-record>app=Pro3EM</txt-record>
    <txt-record>ver=2.2.1</txt-record>
  </service>
</service-group>
